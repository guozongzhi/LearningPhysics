# =============================================================================
# LearningPhysics Backend - 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填入实际值:  cp .env.example .env
# =============================================================================

# --- 数据库配置 ---
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/learningphysics"

# --- AI 模型配置 ---
# 支持 OpenAI / Gemini / 豆包 等兼容 OpenAI 接口的服务
OPENAI_API_KEY="your-api-key-here"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4-turbo-preview"

# --- 安全配置 ---
# JWT 签名密钥 (生产环境中必须设置固定值)
# SECRET_KEY="your-random-secret-key"
