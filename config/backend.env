# =============================================================================
# LearningPhysics Backend - 生产部署配置
# =============================================================================

# --- 数据库配置 (使用本地 PostgreSQL) ---
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/learningphysics"

# --- AI 模型配置 ---
# 支持 OpenAI / Gemini / 豆包 等兼容 OpenAI 接口的服务
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.minimaxi.com/v1"
OPENAI_MODEL="MiniMax-M2.7"

# --- 安全配置 ---
# JWT 签名密钥 (生产环境中必须设置固定值)
SECRET_KEY="your-secure-random-secret-key-change-me-in-production"
