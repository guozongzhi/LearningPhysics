# =============================================================================
# LearningPhysics Backend - 配置模板
# 复制此文件为 backend.env 并修改配置
# =============================================================================

# --- 数据库配置 ---
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/learningphysics"

# --- AI 模型配置 ---
# 支持 OpenAI / Gemini / 豆包 等兼容 OpenAI 接口的服务
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_MODEL="doubao-seed-2-0-mini-260215"

# --- 安全配置 ---
# JWT 签名密钥 (生产环境中必须设置为随机字符串)
SECRET_KEY="your-secure-random-secret-key-change-me-in-production"
